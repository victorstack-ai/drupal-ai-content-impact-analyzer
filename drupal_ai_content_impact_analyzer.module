<?php

/**
 * @file
 * Primary module hooks for AI Content Impact Analyzer.
 */

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_insert().
 */
function drupal_ai_content_impact_analyzer_entity_insert(EntityInterface $entity) {
  _drupal_ai_content_impact_analyzer_check($entity);
}

/**
 * Implements hook_entity_update().
 */
function drupal_ai_content_impact_analyzer_entity_update(EntityInterface $entity) {
  _drupal_ai_content_impact_analyzer_check($entity);
}

/**
 * Helper to check impact on save.
 */
function _drupal_ai_content_impact_analyzer_check(EntityInterface $entity) {
  if ($entity->getEntityTypeId() !== 'node' || !$entity->hasField('body')) {
    return;
  }
  
  // Just log it on save for now.
  $text = $entity->get('body')->value;
  /** @var \Drupal\ai_content_impact_analyzer\Service\ImpactScorer $scorer */
  $scorer = \Drupal::service('ai_content_impact_analyzer.scorer');
  $result = $scorer->calculateScore($text ?? '');

  \Drupal::logger('ai_content_impact_analyzer')->info('Node @id saved. Impact: @summary (@score)', [
    '@id' => $entity->id(),
    '@summary' => $result['summary'],
    '@score' => $result['score'],
  ]);
}
